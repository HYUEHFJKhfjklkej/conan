[settings]
os=Windows
arch=x86_64
compiler=msvc
compiler.version=194
compiler.cppstd=17
compiler.runtime=dynamic
build_type=Release

[platform_tool_requires]
# Use system-provided tools instead of building them via Conan.
# Required because we operate in --no-remote mode (no Conan-built tools available).
cmake/3.25.1
perl/5.32.1
nasm/2.16.01
strawberryperl/5.32.1.1

{% set tools_dir = profile_dir + "/../tools/windows" %}

[buildenv]
# Используем тулзы внутри репо (распакованы test-windows\install_deps.bat
# в conan-recipes\tools\windows\). profile_dir даёт путь к этому профилю,
# tools_dir — путь к bundle.  Запасные системные пути добавлены в конец
# на случай, если bundle отсутствует, но Strawberry Perl/NASM есть в системе.
PATH=+(path){{ tools_dir }}/strawberryperl/perl/bin
PATH=+(path){{ tools_dir }}/nasm
PATH+=(path)C:\Strawberry\perl\bin
PATH+=(path)C:\Program Files\NASM
