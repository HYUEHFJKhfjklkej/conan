[settings]
os=Windows
arch=x86_64
compiler=msvc
compiler.version=194
compiler.cppstd=17
compiler.runtime=dynamic
build_type=Release

[platform_tool_requires]
# Use system-provided tools instead of building them via Conan.
# Required because we operate in --no-remote mode (no Conan-built tools available).
cmake/3.25.1
perl/5.32.1
nasm/2.16.01
strawberryperl/5.32.1.1

[buildenv]
# Используем перенесённые в репо тулзы (распакованы test-windows\install_deps.bat
# в conan-recipes\tools\windows\). Conan подставит {{ os.path.join(profile_dir, ...) }}
# при загрузке профиля.  Запасные системные пути добавлены в конец на случай,
# если репо склонировано в другое место.
PATH=+(path){{ os.path.join(profile_dir, "..", "tools", "windows", "strawberryperl", "perl", "bin") }}
PATH=+(path){{ os.path.join(profile_dir, "..", "tools", "windows", "nasm") }}
PATH+=(path)C:\Strawberry\perl\bin
PATH+=(path)C:\Program Files\NASM
