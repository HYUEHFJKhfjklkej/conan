[settings]
os=Windows
compiler=msvc
compiler.version=193
compiler.cppstd=17
compiler.runtime=dynamic
build_type=Debug
arch=x86_64

[platform_tool_requires]
cmake/3.25.1
perl/5.32.1
nasm/2.16.01
strawberryperl/5.32.1.1

{% set tools_dir = profile_dir + "/../tools/windows" %}

[buildenv]
PATH=+(path){{ tools_dir }}/strawberryperl/perl/bin
PATH=+(path){{ tools_dir }}/nasm
PATH+=(path)C:\Strawberry\perl\bin
PATH+=(path)C:\Program Files\NASM
